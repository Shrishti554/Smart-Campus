<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Placement Admin Dashboard — SmartCampus</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --sidebar-w: 250px;
      --bg: #f0f4f8;
      --card-bg: #fff;
      --accent: #2563eb;
      --accent-hover: #1d4ed8;
      --text: #1e293b;
      --text-muted: #64748b;
      --border: #e2e8f0;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
    }
    * { box-sizing: border-box; }
    body {
      font-family: 'DM Sans', -apple-system, sans-serif;
      background: var(--bg);
      margin: 0;
      padding: 0;
      color: var(--text);
    }
    .sidebar {
      width: var(--sidebar-w);
      height: 100vh;
      background: var(--card-bg);
      position: fixed;
      left: 0;
      top: 0;
      box-shadow: 2px 0 12px rgba(0,0,0,0.06);
      padding-top: 1.25rem;
    }
    .sidebar .logo {
      text-align: center;
      margin-bottom: 1.5rem;
      padding: 0 1rem;
    }
    .sidebar .logo h2 { margin: 0; font-size: 1.35rem; color: var(--text); }
    .sidebar .logo h2 span { color: var(--accent); }
    .sidebar ul { list-style: none; padding: 0; margin: 0; }
    .sidebar ul li {
      padding: 0.75rem 1.25rem;
      margin: 0 0.5rem;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .sidebar ul li:hover, .sidebar ul li.active {
      background: var(--accent);
      color: white;
    }
    .sidebar ul li a {
      text-decoration: none;
      color: inherit;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .main {
      margin-left: var(--sidebar-w);
      padding: 2rem;
    }
    .header {
      background: var(--card-bg);
      padding: 1.5rem 2rem;
      border-radius: 1rem;
      margin-bottom: 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header h1 { margin: 0; font-size: 1.75rem; }
    .header .user-info {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    .stat-card {
      background: var(--card-bg);
      padding: 1.5rem;
      border-radius: 1rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      border-left: 4px solid var(--accent);
    }
    .stat-card h3 { margin: 0 0 0.5rem 0; font-size: 2rem; color: var(--accent); }
    .stat-card p { margin: 0; color: var(--text-muted); }
    .content-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
    }
    .card {
      background: var(--card-bg);
      border-radius: 1rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      padding: 1.5rem;
    }
    .card h2 { margin: 0 0 1rem 0; font-size: 1.25rem; }
    .chart-container {
      position: relative;
      height: 300px;
      margin-bottom: 1rem;
    }
    .quick-actions {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .action-btn {
      padding: 1rem;
      background: var(--card-bg);
      border: 2px solid var(--border);
      border-radius: 0.5rem;
      text-decoration: none;
      color: var(--text);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.2s;
    }
    .action-btn:hover {
      border-color: var(--accent);
      background: #f8fafc;
    }
    .action-btn i {
      font-size: 1.5rem;
      color: var(--accent);
    }
    .table-container {
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th {
      background: #f8fafc;
      padding: 0.75rem;
      text-align: left;
      font-weight: 600;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
    }
    td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
    }
    tr:hover {
      background: #f8fafc;
    }
    .status-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.8rem;
      font-weight: 500;
      display: inline-block;
    }
    .status-applied { background: #dbeafe; color: #1e40af; }
    .status-shortlisted { background: #fef3c7; color: #92400e; }
    .status-interview { background: #e9d5ff; color: #6b21a8; }
    .status-selected { background: #d1fae5; color: #065f46; }
    .status-rejected { background: #fee2e2; color: #991b1b; }
    .salary-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 1rem;
    }
    .salary-stat {
      text-align: center;
      padding: 1rem;
      background: #f8fafc;
      border-radius: 0.5rem;
    }
    .salary-stat .value {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--success);
    }
    .salary-stat .label {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }
    .btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 0.5rem;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
      transition: all 0.2s;
      font-size: 1rem;
    }
    .btn-primary {
      background: var(--accent);
      color: white;
    }
    .btn-primary:hover {
      background: var(--accent-hover);
    }
    .view-all {
      text-align: center;
      margin-top: 1rem;
    }
    @media (max-width: 1024px) {
      .content-grid {
        grid-template-columns: 1fr;
      }
      .quick-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="logo">
      <h2>Smart<span>Campus</span></h2>
    </div>
    <ul>
      <li><a href="/dashboard"><i class="fas fa-home"></i> Dashboard</a></li>
      <li class="active"><a href="/placement/admin"><i class="fas fa-briefcase"></i> Placement Admin</a></li>
      <li><a href="/placement/admin/jobs"><i class="fas fa-plus-circle"></i> Manage Jobs</a></li>
      <li><a href="/placement/admin/companies"><i class="fas fa-building"></i> Companies</a></li>
      <li><a href="/placement/admin/interviews"><i class="fas fa-calendar-check"></i> Interviews</a></li>
      <li><a href="/placement/admin/analytics"><i class="fas fa-chart-bar"></i> Analytics</a></li>
      <li><a href="/placement/applications"><i class="fas fa-file-alt"></i> Applications</a></li>
      <li><a href="/library"><i class="fas fa-book"></i> Library</a></li>
      <li><a href="/contact"><i class="fas fa-envelope"></i> Contact</a></li>
      <li><a href="/profile"><i class="fas fa-user"></i> Profile</a></li>
      <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </aside>

  <main class="main">
    <div class="header">
      <h1>Placement Admin Dashboard</h1>
      <div class="user-info">
        <span>Welcome, <%= user.fullName || user.email %></span>
        <i class="fas fa-user-circle fa-2x"></i>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <h3><%= stats.totalJobs %></h3>
        <p>Active Jobs</p>
      </div>
      <div class="stat-card">
        <h3><%= stats.totalApplications %></h3>
        <p>Total Applications</p>
      </div>
      <div class="stat-card">
        <h3><%= stats.selectedStudents %></h3>
        <p>Students Placed</p>
      </div>
      <div class="stat-card">
        <h3><%= stats.placementRate %>%</h3>
        <p>Placement Rate</p>
      </div>
    </div>

    <div class="content-grid">
      <div class="card">
        <h2>Application Trends</h2>
        <div class="chart-container">
          <canvas id="applicationChart"></canvas>
        </div>
        <div class="salary-stats">
          <div class="salary-stat">
            <div class="value">₹<%= Math.round(stats.salaryStats.avgSalary).toLocaleString() %></div>
            <div class="label">Average Package</div>
          </div>
          <div class="salary-stat">
            <div class="value">₹<%= stats.salaryStats.maxSalary.toLocaleString() %></div>
            <div class="label">Highest Package</div>
          </div>
          <div class="salary-stat">
            <div class="value">₹<%= stats.salaryStats.minSalary.toLocaleString() %></div>
            <div class="label">Lowest Package</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Quick Actions</h2>
        <div class="quick-actions">
          <a href="/placement/admin/jobs/new" class="action-btn">
            <i class="fas fa-plus-circle"></i>
            <span>Post New Job</span>
          </a>
          <a href="/placement/admin/companies" class="action-btn">
            <i class="fas fa-building"></i>
            <span>Add Company</span>
          </a>
          <a href="/placement/admin/interviews" class="action-btn">
            <i class="fas fa-calendar-check"></i>
            <span>Schedule Interview</span>
          </a>
          <a href="/placement/admin/analytics" class="action-btn">
            <i class="fas fa-chart-bar"></i>
            <span>View Analytics</span>
          </a>
        </div>
      </div>
    </div>

    <div class="content-grid">
      <div class="card">
        <h2>Recent Applications</h2>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Student</th>
                <th>Job</th>
                <th>Company</th>
                <th>Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% recentApplications.slice(0, 5).forEach(application => { %>
                <tr>
                  <td><%= application.student.fullName || application.student.email %></td>
                  <td><%= application.job.title %></td>
                  <td><%= application.company.name %></td>
                  <td><%= new Date(application.appliedAt).toLocaleDateString() %></td>
                  <td>
                    <span class="status-badge status-<%= application.status.toLowerCase().replace(' ', '-') %>">
                      <%= application.status %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="view-all">
          <a href="/placement/applications" class="btn btn-primary">View All Applications</a>
        </div>
      </div>

      <div class="card">
        <h2>Upcoming Interviews</h2>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Student</th>
                <th>Company</th>
                <th>Date</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              <% upcomingInterviews.slice(0, 5).forEach(interview => { %>
                <tr>
                  <td><%= interview.student.fullName || interview.student.email %></td>
                  <td><%= interview.company.name %></td>
                  <td><%= new Date(interview.date).toLocaleDateString() %></td>
                  <td><%= interview.time %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <div class="view-all">
          <a href="/placement/admin/interviews" class="btn btn-primary">Manage Interviews</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Application trends chart
    const ctx = document.getElementById('applicationChart').getContext('2d');
    
    // Generate sample data for chart
    const applicationData = [15, 23, 18, 29, 33, 41];
    const selectedData = [3, 5, 4, 8, 6, 12];
    
    const applicationChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
          label: 'Applications',
          data: applicationData,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.1)',
          tension: 0.4
        }, {
          label: 'Selected',
          data: selectedData,
          borderColor: '#10b981',
          backgroundColor: 'rgba(16, 185, 129, 0.1)',
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'top',
          }
        },
        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  </script>
</body>
</html>
